##########################################################
# CPaaS Voice AI Platform — Environment Variables
# Architecture v2.0: OpenSIPS + rtpengine + FreeSWITCH + LiveKit
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
##########################################################

# ─────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_postgres_password_here
POSTGRES_DB=cpaas_db
POSTGRES_USER=cpaas

# ─────────────────────────────────────────────────────────────────
# OBJECT STORAGE (MinIO)
# ─────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_strong_minio_secret_key

# ─────────────────────────────────────────────────────────────────
# LIVEKIT
# ─────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
# Must be at least 32 characters
LIVEKIT_API_SECRET=your_livekit_secret_at_least_32_chars_long

# ─────────────────────────────────────────────────────────────────
# AI PROVIDERS
# ─────────────────────────────────────────────────────────────────
# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio

# Alibaba Qwen Omni (optional, alternative AI provider)
ALIBABA_API_KEY=your_alibaba_api_key

# ─────────────────────────────────────────────────────────────────
# FREESWITCH (replaces Asterisk)
# ─────────────────────────────────────────────────────────────────
# ESL Password — must match freeswitch.xml event_socket config
ESL_PASSWORD=your_strong_esl_password_change_this

# FreeSWITCH SIP domain
FREESWITCH_DOMAIN=freeswitch.your-domain.com

# External SIP IP (your server's public IP)
# Leave empty for auto-detection
EXT_SIP_IP=

# SIP Trunk credentials (your PSTN carrier - BYOC)
SIP_TRUNK_HOST=sip.your-carrier.com
SIP_TRUNK_USER=your_trunk_username
SIP_TRUNK_PASSWORD=your_trunk_password

# ─────────────────────────────────────────────────────────────────
# OPENSIPS
# ─────────────────────────────────────────────────────────────────
OPENSIPS_DB_HOST=postgres
OPENSIPS_DB_USER=opensips
OPENSIPS_DB_PASS=opensips_db_password

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────
# JWT signing key for ASP.NET auth (min 32 chars)
JWT_SECRET=your_jwt_signing_key_min_32_characters_long

# Internal API key — shared between FreeSWITCH, Go Agent, and ASP.NET
# Must be same across all services
INTERNAL_API_KEY=your_internal_shared_secret_key

# ─────────────────────────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_admin_password

# ─────────────────────────────────────────────────────────────────
# DOMAINS (Production)
# ─────────────────────────────────────────────────────────────────
API_DOMAIN=api.your-cpaas-domain.com
APP_DOMAIN=app.your-cpaas-domain.com
WS_DOMAIN=ws.your-cpaas-domain.com
WEBHOOK_DOMAIN=hook.your-cpaas-domain.com

# SSL Email for Let's Encrypt
ACME_EMAIL=ssl@your-domain.com
